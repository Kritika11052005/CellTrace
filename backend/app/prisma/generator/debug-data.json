{
  "datamodel": "// CellTrace — Prisma Schema\n// Database: Neon PostgreSQL\n\ngenerator client {\n  provider             = \"prisma-client-py\"\n  interface            = \"asyncio\"\n  recursive_type_depth = 5\n  output               = \"../app/prisma\"\n}\n\ndatasource db {\n  provider = \"postgresql\"\n  url      = env(\"DATABASE_URL\")\n}\n\n// ─── Enums ───────────────────────────────────────────────\n\nenum UserRole {\n  operator\n  admin\n}\n\nenum ChainStatus {\n  pending\n  confirmed\n  failed\n}\n\n// ─── Users ───────────────────────────────────────────────\n\nmodel User {\n  id             String       @id @default(uuid()) @db.Uuid\n  email          String       @unique\n  password_hash  String\n  role           UserRole     @default(operator)\n  wallet_address String?\n  created_at     DateTime     @default(now()) @db.Timestamptz()\n  predictions    Prediction[]\n  audit_logs     AuditLog[]\n\n  @@map(\"users\")\n}\n\n// ─── Batteries ───────────────────────────────────────────\n\nmodel Battery {\n  id                  String        @id // battery serial number / ID\n  manufacturer        String?\n  model               String?\n  chemistry           String? // e.g. NMC, LFP, NCA, LCO\n  nominal_capacity_ah Float?\n  created_at          DateTime      @default(now()) @db.Timestamptz()\n  predictions         Prediction[]\n  chain_records       ChainRecord[]\n\n  @@map(\"batteries\")\n}\n\n// ─── Predictions ─────────────────────────────────────────\n\nmodel Prediction {\n  id               String   @id @default(uuid()) @db.Uuid\n  battery_id       String\n  soh_percent      Float\n  rul_cycles       Int?\n  rul_fraction     Float? // 0-1 scale remaining useful life fraction\n  confidence_range Json? // { soh_low, soh_high, rul_low, rul_high }\n  has_knee_point   Boolean?\n  model_version    String\n  input_data_ref   String? // pointer to raw cycle-data file\n  report_hash      String? // keccak256 hash of canonical report payload\n  created_by       String   @db.Uuid\n  created_at       DateTime @default(now()) @db.Timestamptz()\n\n  battery       Battery       @relation(fields: [battery_id], references: [id])\n  user          User          @relation(fields: [created_by], references: [id])\n  chain_records ChainRecord[]\n\n  @@index([battery_id])\n  @@index([created_by])\n  @@map(\"predictions\")\n}\n\n// ─── Chain Records ───────────────────────────────────────\n\nmodel ChainRecord {\n  id               String      @id @default(uuid()) @db.Uuid\n  prediction_id    String      @db.Uuid\n  battery_id       String\n  tx_hash          String      @unique\n  contract_address String\n  data_hash        String // should equal predictions.report_hash\n  event_type       String\n  block_number     Int?\n  chain_timestamp  DateTime?   @db.Timestamptz()\n  status           ChainStatus @default(pending)\n  created_at       DateTime    @default(now()) @db.Timestamptz()\n\n  prediction Prediction @relation(fields: [prediction_id], references: [id])\n  battery    Battery    @relation(fields: [battery_id], references: [id])\n\n  @@index([battery_id])\n  @@index([prediction_id])\n  @@map(\"chain_records\")\n}\n\n// ─── Audit Log ───────────────────────────────────────────\n\nmodel AuditLog {\n  id         String   @id @default(uuid()) @db.Uuid\n  actor_id   String?  @db.Uuid\n  action     String // e.g. login, predict, chain_write_attempt, verify_check\n  ip_address String?\n  metadata   Json?\n  created_at DateTime @default(now()) @db.Timestamptz()\n\n  actor User? @relation(fields: [actor_id], references: [id])\n\n  @@index([actor_id])\n  @@index([action])\n  @@map(\"audit_log\")\n}\n",
